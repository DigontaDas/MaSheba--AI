{
  "expo": {
    "name": "MaSheba AI",
    "slug": "maasheba-ai",
    "scheme": "maasheba",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#fcf6f2"
    },
    "android": {
      "package": "com.maasheba.mobile",
      "minSdkVersion": 26,
      "jsEngine": "hermes",
      "enableProguardInReleaseBuilds": true,
      "enableShrinkResourcesInReleaseBuilds": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fcf6f2"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },

    "ios": {
      "bundleIdentifier": "com.maasheba.mobile",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "MaSheba uses speech recognition for optional voice input.",
        "NSMicrophoneUsageDescription": "MaSheba uses the microphone for optional voice input."
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "expo-background-task",
      "expo-font",
      "expo-image"
    ],
    "extra": {
      "apiBaseUrl": "Set EXPO_PUBLIC_API_BASE_URL in the mobile environment.",
      "supabaseUrl": "Set EXPO_PUBLIC_SUPABASE_URL in the mobile environment."
    }
  }
}
